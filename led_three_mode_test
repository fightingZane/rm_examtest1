/**
  * @brief  The application entry point.
  * @retval int
  */
int main(void)
{

  /* USER CODE BEGIN 1 */

  /* USER CODE END 1 */

  /* MCU Configuration--------------------------------------------------------*/

  /* Reset of all peripherals, Initializes the Flash interface and the Systick. */
  HAL_Init();

  /* USER CODE BEGIN Init */

  /* USER CODE END Init */

  /* Configure the system clock */
  SystemClock_Config();

  /* USER CODE BEGIN SysInit */

  /* USER CODE END SysInit */

  /* Initialize all configured peripherals */
  MX_GPIO_Init();
  MX_TIM1_Init();
  MX_TIM3_Init();
  MX_USART1_UART_Init();
  MX_I2C1_Init();
  /* USER CODE BEGIN 2 */
  HAL_TIM_PWM_Start(&htim1, TIM_CHANNEL_1);
  HAL_TIM_Encoder_Start(&htim3, TIM_CHANNEL_1);
  HAL_TIM_Encoder_Start(&htim3, TIM_CHANNEL_2);

  OLED_Init();
  OLED_Show_Mode(current_mode);
  /* USER CODE END 2 */

  /* Infinite loop */
  /* USER CODE BEGIN WHILE */
  uint8_t btn1_pre = 1, btn1_cur = 1;
  uint8_t btn2_pre = 1, btn2_cur = 1;
  uint8_t btn3_pre = 1, btn3_cur = 1;
  uint32_t blink_tick = 0;
  uint8_t blink_state = 0;

  uint32_t last_vofa_send = 0;
  
  while(1)
  {
    // ---- 按键扫描 ----
    btn1_pre = btn1_cur;
    btn1_cur = HAL_GPIO_ReadPin(GPIOA, GPIO_PIN_0);
    if(btn1_cur != btn1_pre && btn1_cur == 0)
			 {
					HAL_Delay (10);
				  if(HAL_GPIO_ReadPin(GPIOA, GPIO_PIN_0) == 0)
						{
						 current_mode = MODE_BREATH;
						}
			 }
			 
    btn2_pre = btn2_cur;
    btn2_cur = HAL_GPIO_ReadPin(GPIOA, GPIO_PIN_1);			 
    if(btn2_cur != btn2_pre && btn2_cur == 0)
			 {
					HAL_Delay (10);
				  if(HAL_GPIO_ReadPin(GPIOA, GPIO_PIN_1) == 0)
						{
						 current_mode = MODE_ADJUST;
						}
			 }
			 
    btn3_pre = btn3_cur;
    btn3_cur = HAL_GPIO_ReadPin(GPIOA, GPIO_PIN_2);
//    if(btn3_cur != btn3_pre && btn3_cur == 0) current_mode = MODE_BLINK;
    if(btn3_cur != btn3_pre && btn3_cur == 0)
			 {
					HAL_Delay (10);
				  if(HAL_GPIO_ReadPin(GPIOA, GPIO_PIN_2) == 0)
						{
						 current_mode = MODE_BLINK;
						}
			 }
			 
			 
    // ---- 模式切换刷新 ----
    if(current_mode != last_mode)
    {
        OLED_Show_Mode(current_mode);
        last_mode = current_mode;
        last_brightness = 0xFF;   // 强制刷新亮度显示
    }

    // ---- 模式执行 ----
    switch(current_mode)
    {
      case MODE_BREATH:
      {
        float t = HAL_GetTick() * 0.001f;
        float duty = 0.5f * sin(4 * 3.1415926f * t) + 0.5f;
        uint16_t arr = __HAL_TIM_GET_AUTORELOAD(&htim1);
        uint16_t crr = duty * (arr + 1);
        __HAL_TIM_SET_COMPARE(&htim1, TIM_CHANNEL_1, crr);
        break;
      }
      case MODE_ADJUST:
      {
        uint16_t cnt = __HAL_TIM_GET_COUNTER(&htim3);
        float duty = cnt / 1.0f;
        if(duty > 10) duty = 10;
        if(duty < 0)  duty = 0;
        uint16_t arr = __HAL_TIM_GET_AUTORELOAD(&htim1);
        uint16_t crr = (duty / 10.0f) * (arr + 1);
        __HAL_TIM_SET_COMPARE(&htim1, TIM_CHANNEL_1, crr);
//        HAL_UART_Transmit(&huart1, (uint8_t*)&cnt, 2, 10);
        break;
      }
      case MODE_BLINK:
      {
        if(HAL_GetTick() - blink_tick >= 500)
        {
          blink_tick = HAL_GetTick();
          blink_state = !blink_state;
          uint16_t arr = __HAL_TIM_GET_AUTORELOAD(&htim1);
          if(blink_state)
            __HAL_TIM_SET_COMPARE(&htim1, TIM_CHANNEL_1, arr);
          else
            __HAL_TIM_SET_COMPARE(&htim1, TIM_CHANNEL_1, 0);
        }
        break;
      }
    }

    // ---- 定时刷新亮度显示 ----
    // ---- 亮度显示：仅手动调节模式 ----
    if (current_mode == MODE_ADJUST | current_mode == MODE_BLINK )
    {
        uint32_t now = HAL_GetTick();
        uint16_t ccr = __HAL_TIM_GET_COMPARE(&htim1, TIM_CHANNEL_1);
        uint16_t arr = __HAL_TIM_GET_AUTORELOAD(&htim1);
        uint8_t brightness = (uint32_t)ccr * 100 / (arr + 1);  // 防止溢出

        // 亮度变化超过 3% 或距上次更新超过 500ms 才刷新
        if (abs((int)brightness - (int)last_brightness) >= 3 || 
            (now - last_oled_update >= 500))
        {
            OLED_Show_Brightness(brightness);
            last_brightness = brightness;
            last_oled_update = now;
        }
    } 
		
				uint32_t now = HAL_GetTick();
				if (now - last_vofa_send >= 50)   // 50ms 发送一次，频率 20Hz，足够平滑
				{
						last_vofa_send = now;

						// 获取当前 PWM 占空比对应的亮度百分比
						uint16_t ccr = __HAL_TIM_GET_COMPARE(&htim1, TIM_CHANNEL_1);
						uint16_t arr = __HAL_TIM_GET_AUTORELOAD(&htim1);
						float brightness = (float)((uint32_t)ccr * 100) / (arr + 1);  // 0~100 浮点数

						// 使用 sprintf 格式化为字符串，并添加换行符
						char vofa_buf[20];
						int len = sprintf(vofa_buf, "%.2f\r\n", brightness);

						// 通过串口1发送
						HAL_UART_Transmit(&huart1, (uint8_t*)vofa_buf, len, 100);
}




	}
    /* USER CODE END WHILE */

    /* USER CODE BEGIN 3 */

  /* USER CODE END 3 */
}

