	void OLED_Show_Brightness(uint8_t percent)
	{
			char buf[8];
			sprintf(buf, "%3d%%", percent);
			OLED_ShowString(0, 4, "BRIGHT:", 16);
			OLED_ShowString(64, 4, buf, 16);
			OLED_Refresh();
	}

	void OLED_Show_Mode(LightMode mode)
	{
    OLED_Clear();
    OLED_ShowString(0, 0, "LED MODE:", 16);
    switch(mode)
    {
        case MODE_BREATH:
            OLED_ShowString(0, 2, "BREATHING", 16);
            break;
        case MODE_ADJUST:
            OLED_ShowString(0, 2, "ENCODER", 16);
            break;
        case MODE_BLINK:
            OLED_ShowString(0, 2, "BLINKING", 16);
            break;
    }
    OLED_Refresh();
}
