typedef enum {
    MODE_BREATH  = 0,
    MODE_ADJUST  = 1,
    MODE_BLINK   = 2
} LightMode;

LightMode current_mode = MODE_BREATH;
uint8_t last_mode = 0xFF;

// 亮度显示控制
uint8_t  last_brightness = 0xFF;
uint32_t last_oled_update = 0;
/* USER CODE END PV */

